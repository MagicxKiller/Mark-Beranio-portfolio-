<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mark Beranio | Portfolio</title>
    <meta name="title" content="Mark Beranio - Portfolio">
    <meta name="description" content="Aspiring Professional Developer practicing HTML, CSS, JS, and PHP.">
    
    <style>
        :root {
            --primary-color: #00d2ff;
            --bg-overlay: rgba(0, 0, 0, 0.75);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        body {
            background-image: url('https://raw.githubusercontent.com/MagicxKiller/Killing-Farm/refs/heads/main/Ling%20Collector%20skin%20Walpapers%20MLBB%204K.jpeg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 20px;
        }

        .profile-card {
            background: var(--bg-overlay);
            backdrop-filter: blur(10px); /* Adds a modern frosted glass effect */
            padding: 40px 30px;
            border-radius: 24px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            max-width: 450px;
            width: 100%;
            border: 1px solid var(--glass-border);
        }

        .profile-img {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--primary-color);
            margin-bottom: 20px;
            box-shadow: 0 0 20px rgba(0, 210, 255, 0.3);
            transition: transform 0.3s ease;
        }

        .profile-img:hover {
            transform: scale(1.05);
        }

        .typing-text {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 15px;
            height: 45px;
            color: var(--primary-color);
        }

        .cursor {
            display: inline-block;
            width: 3px;
            background-color: var(--primary-color);
            margin-left: 5px;
            animation: blink 1s infinite;
        }

        @keyframes blink {
            50% { opacity: 0; }
        }

        .description {
            font-size: 1rem;
            line-height: 1.6;
            color: #ccc;
            margin-bottom: 30px;
        }

        .skills {
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .skill-tag {
            background: rgba(255, 255, 255, 0.08);
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 1px solid var(--glass-border);
            transition: all 0.2s ease;
        }

        .skill-tag:hover {
            background: var(--primary-color);
            color: #000;
            border-color: var(--primary-color);
        }

        @media (max-width: 480px) {
            .typing-text { font-size: 1.8rem; }
            .profile-card { padding: 30px 20px; }
        }
    </style>
</head>
<body>

    <main class="profile-card">
        <img src="https://raw.githubusercontent.com/MagicxKiller/Killing-Farm/refs/heads/main/1771830262411.jpg" alt="Mark Beranio" class="profile-img">
        
        <h1 class="typing-text">
            <span id="text"></span><span class="cursor"></span>
        </h1>

        <p class="description">
            Aspiring professional developer. Currently mastering JavaScript, HTML, CSS, and PHP to build high-performance web experiences.
        </p>

        <div class="skills">
            <span class="skill-tag">HTML5</span>
            <span class="skill-tag">CSS3</span>
            <span class="skill-tag">JS</span>
            <span class="skill-tag">PHP</span>
            <span class="skill-tag">Python</span>
            <span class="skill-tag">C++</span>
        </div>
    </main>

    <script>
        const textElement = document.getElementById('text');
        const textToType = "Mark Beranio";
        let charIndex = 0;
        let isDeleting = false;

        function type() {
            const currentText = textToType;
            let typeSpeed = isDeleting ? 50 : 150;

            if (!isDeleting && charIndex < currentText.length) {
                textElement.textContent += currentText.charAt(charIndex);
                charIndex++;
            } else if (isDeleting && charIndex > 0) {
                textElement.textContent = currentText.substring(0, charIndex - 1);
                charIndex--;
            }

            if (charIndex === currentText.length) {
                isDeleting = true;
                typeSpeed = 3000; // Stay visible for 3s
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                typeSpeed = 500;
            }

            setTimeout(type, typeSpeed);
        }

        window.onload = type;
    </script>
</body>
</html>
